# /etc/sonshine/env — copy here, chmod 600, owned by root
# Loaded by systemd EnvironmentFile directive

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/sonshine_inventory
SPRING_DATASOURCE_USERNAME=sonshine
SPRING_DATASOURCE_PASSWORD=sonshine

SERVER_PORT=443
SSL_ENABLED=true
SSL_KEY_STORE=/opt/sonshine-inventory/keystore.p12
SSL_KEY_STORE_PASSWORD=changeme
SSL_KEY_STORE_TYPE=PKCS12
SSL_KEY_ALIAS=cloudflare-origin
